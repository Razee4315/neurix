{
  "$schema": "../gen/schemas/capabilities.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "context": "main",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:webview:default",
    "opener:default",
    "opener:allow-open-url",
    "store:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-delete",
    "shell:default",
    "shell:allow-open",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://localhost:*/**" },
        { "url": "http://127.0.0.1:*/**" },
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    },
    {
      "identifier": "http:allow-fetch-send",
      "allow": [
        { "url": "http://localhost:*/**" },
        { "url": "http://127.0.0.1:*/**" },
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    }
  ]
}
